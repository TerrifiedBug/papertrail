# Copy to `.env` (gitignored) and adjust. Runtime config only — NO secrets here.
# Real tokens/devices live in seed.json (built from secrets.example.py).

# Path to the sqlite database file.
PAPERTRAIL_DB=./papertrail.db

# Path to the JSON seed file (devices + plaintext tokens, hashed on first run).
# Tokens here ARE secret -> keep seed.json out of git (see .gitignore).
PAPERTRAIL_SEED_FILE=./seed.json

# Hard request-body cap in bytes (>cap -> 413). Contract = 8 KiB.
PAPERTRAIL_MAX_BODY_BYTES=8192
