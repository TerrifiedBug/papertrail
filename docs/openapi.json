    "/api/firmware/manifest": {
      "get": {
        "tags": [
          "firmware"
        ],
        "summary": "Firmware Manifest",
        "description": "The bundled firmware manifest hashed at startup. Auth: any valid device\ntoken OR the admin token. The device diffs this against its last-applied\nmanifest.json and pulls only the files whose sha changed.",
        "operationId": "firmware_manifest_api_firmware_manifest_get",
        "responses": {
          "200": {
            "description": "Firmware version + per-file sha256 map.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "version": "a1b2c3d4e5f6",
                  "files": {
                    "main.py": "\u202664 hex\u2026",
                    "lib/uQR.py": "\u202664 hex\u2026"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/firmware/file": {
      "get": {
        "tags": [
          "firmware"
        ],
        "summary": "Firmware File",
        "description": "Raw bytes of ONE firmware file. Auth: any valid device token OR the\nadmin token. ``path`` MUST be a manifest key \u2014 anything else (missing,\n``..``/absolute/traversal, unknown) is rejected (400/404), never read\noff-bundle.",
        "operationId": "firmware_file_api_firmware_file_get",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "a path that is a key in the firmware manifest",
              "title": "Path"
            },
            "description": "a path that is a key in the firmware manifest"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
