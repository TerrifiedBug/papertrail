      }
    },
    "/api/firmware/provision-file": {
      "get": {
        "tags": [
          "firmware"
        ],
        "summary": "Firmware Provision File",
        "description": "Serve a device-local PROVISIONING TEMPLATE from the firmware dir, for a\nbrand-new Pico that has no config.py yet (config.py is intentionally NOT in\nthe OTA manifest, so the flasher cannot pull+patch it). This is SEPARATE\nfrom the OTA bundle: ``path`` must be in a tiny fixed allowlist\n(``config.py`` / ``secrets.example.py``) \u2014 anything else is 404. Auth: any\nvalid device token OR the admin token (same gate as the OTA endpoints).",
        "operationId": "firmware_provision_file_api_firmware_provision_file_get",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "a provisioning template name: config.py or secrets.example.py",
              "title": "Path"
            },
            "description": "a provisioning template name: config.py or secrets.example.py"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
