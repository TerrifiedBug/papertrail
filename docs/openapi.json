    "/api/devices/{device_id}/current": {
      "get": {
        "tags": [
          "device"
        ],
        "summary": "Get Current",
        "operationId": "get_current_api_devices__device_id__current_get",
        "parameters": [
          {
            "name": "device_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Device Id"
            }
          },
          {
            "name": "batt",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "battery %, clamped 0..100",
              "title": "Batt"
            },
            "description": "battery %, clamped 0..100"
          },
          {
            "name": "rssi",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "wifi RSSI dBm, clamped -120..0",
              "title": "Rssi"
            },
            "description": "wifi RSSI dBm, clamped -120..0"
          },
          {
            "name": "fw",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "firmware id, <=16 chars [A-Za-z0-9._-]",
              "title": "Fw"
            },
            "description": "firmware id, <=16 chars [A-Za-z0-9._-]"
          },
          {
            "name": "up",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "uptime seconds, >=0",
              "title": "Up"
            },
            "description": "uptime seconds, >=0"
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved screen + additive control block.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "schema": "pico-paper.v1",
                  "device": "kitchen-01",
                  "layout": "status_card",
                  "content": {
                    "title": "Papertrail",
                    "status": "IDLE",
                    "subtitle": "Waiting for updates",
                    "lines": [
                      "No active messages"
                    ],
                    "footer": "papertrail"
                  },
                  "control": {
                    "poll_interval": 120,
                    "fw": "a1b2c3d4e5f6"
                  },
                  "etag": "c0ffee...",
                  "rendered_at": 1750000000
                }
              }
            }
          },
          "304": {
            "description": "Not Modified (If-None-Match matched the ETag)."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
