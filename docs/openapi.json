            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "examples": {
                "status_card": {
                  "summary": "status_card event",
                  "value": {
                    "schema": "pico-paper.v1",
                    "id": "evt_example_0001",
                    "device": "kitchen-01",
                    "channel": "home.status",
                    "kind": "base",
                    "layout": "status_card",
                    "content": {
                      "title": "Home Server",
                      "status": "OK",
                      "subtitle": "All services nominal",
                      "lines": [
                        "CPU      12%",
                        "RAM      41%",
                        "Disk     63%"
                      ],
                      "footer": "updated 14:02"
                    }
                  }
                },
                "alert": {
                  "summary": "alert event",
                  "value": {
                    "schema": "pico-paper.v1",
                    "id": "evt_example_0001",
                    "device": "kitchen-01",
                    "channel": "home.status",
                    "kind": "base",
                    "layout": "alert",
                    "content": {
                      "severity": "high",
                      "title": "Water Leak",
                      "message": "Sensor under the sink detected moisture.",
                      "footer": "basement-sensor-3"
                    }
                  }
                },
                "list": {
                  "summary": "list event",
                  "value": {
                    "schema": "pico-paper.v1",
                    "id": "evt_example_0001",
                    "device": "kitchen-01",
                    "channel": "home.status",
                    "kind": "base",
                    "layout": "list",
                    "content": {
                      "title": "Shopping",
                      "items": [
                        "Milk",
                        "Eggs",
                        "Coffee beans"
                      ],
                      "footer": "3 items"
                    }
                  }
                },
                "metric": {
                  "summary": "metric event",
                  "value": {
                    "schema": "pico-paper.v1",
                    "id": "evt_example_0001",
                    "device": "kitchen-01",
                    "channel": "home.status",
                    "kind": "base",
                    "layout": "metric",
                    "content": {
                      "label": "Solar output",
                      "value": "3.42",
                      "unit": "kW",
                      "trend": "UP +0.4 kW vs 1h",
                      "footer": "inverter-A"
                    }
                  }
                },
                "qr": {
                  "summary": "qr event",
                  "value": {
                    "schema": "pico-paper.v1",
                    "id": "evt_example_0001",
                    "device": "kitchen-01",
                    "channel": "home.status",
                    "kind": "base",
                    "layout": "qr",
                    "content": {
                      "title": "Guest WiFi",
                      "qr_data": "WIFI:T:WPA;S:GuestNet;P:welcome123;;",
